{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": {
          "type": "STRING",
          "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        "VCPKG_OVERLAY_PORTS": {
          "type": "STRING",
          "value": "${sourceDir}/cmake/ports"
        },
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "VCPKG_FEATURE_FLAGS": "-binarycaching"
      }
    },
    {
      "name": "win64",
      "hidden": true,
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>"
      }
    },
    {
      "name": "msvc",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "toolset": "v145,version=14.51.36223",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "CMAKE_CXX_FLAGS": "/EHsc /MP /W4 /WX /external:W0 $penv{CXXFLAGS}",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /DNDEBUG"
      }
    },
    {
      "name": "flatrim",
      "displayName": "Skyrim SE + AE – Flatrim (x64)",
      "binaryDir": "${sourceDir}/build-flatrim",
      "cacheVariables": {
        "BUILD_SKYRIM_SE": "ON",
        "ENABLE_SKYRIM_SE": "ON",
        "ENABLE_SKYRIM_AE": "ON",
        "ENABLE_SKYRIM_VR": "OFF"
      },
      "inherits": ["base", "win64", "msvc"]
    },
    {
      "name": "skyrim-vr",
      "displayName": "Skyrim VR (x64)",
      "binaryDir": "${sourceDir}/build-skyrim-vr",
      "cacheVariables": {
        "BUILD_SKYRIM_VR": "ON",
        "ENABLE_SKYRIM_SE": "OFF",
        "ENABLE_SKYRIM_AE": "OFF",
        "ENABLE_SKYRIM_VR": "ON"
      },
      "inherits": ["base", "win64", "msvc"]
    }
  ],
  "buildPresets": [
    {
      "name": "flatrim-release",
      "displayName": "Flatrim – Release",
      "configurePreset": "flatrim",
      "configuration": "Release"
    },
    {
      "name": "flatrim-debug",
      "displayName": "Flatrim – Debug",
      "configurePreset": "flatrim",
      "configuration": "Debug"
    },
    {
      "name": "skyrim-vr-release",
      "displayName": "Skyrim VR – Release",
      "configurePreset": "skyrim-vr",
      "configuration": "Release"
    }
  ]
}
