#include <winver.h>

VS_VERSION_INFO VERSIONINFO
    FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
    PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
    FILEFLAGS      0
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_DLL
    FILESUBTYPE    VFT2_UNKNOWN
    BEGIN
        BLOCK "StringFileInfo"
        BEGIN
            BLOCK "040904B0"
            BEGIN
                VALUE "CompanyName",      "Modding Forge"
                VALUE "FileDescription",  "xEdit Linker - Skyrim SE / AE"
                VALUE "FileVersion",      "@PROJECT_VERSION@"
                VALUE "InternalName",     "SSEEditLinker"
                VALUE "LegalCopyright",   "Copyright (C) 2026 Modding Forge. GPL-3.0"
                VALUE "OriginalFilename", "SSEEditLinker.dll"
                VALUE "ProductName",      "xEdit Linker"
                VALUE "ProductVersion",   "@PROJECT_VERSION@"
            END
        END
        BLOCK "VarFileInfo"
        BEGIN
            VALUE "Translation", 0x0409, 0x04B0
        END
    END
